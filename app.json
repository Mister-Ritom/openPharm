{
  "expo": {
    "name": "OpenPharma",
    "slug": "openPharm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "openpharm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "deploymentTarget": "16.1",
      "supportsTablet": true,
      "bundleIdentifier": "me.ritom.openpharm",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "OpenPharma needs access to your camera to scan barcodes and nutrition labels on food products.",
        "NSPhotoLibraryUsageDescription": "OpenPharma needs access to your photos so you can upload product images for analysis.",
        "NSUserTrackingUsageDescription": "This allows us to show you relevant health and lifestyle advertisements based on your needs. You can always opt out later."
      },
      "associatedDomains": [
        "applinks:pharma.ritom.in"
      ]
    },
    "android": {
      "package": "me.ritom.openpharm",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#f7faf8",
        "foregroundImage": "./assets/images/icon.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "com.android.vending.BILLING",
        "com.google.android.gms.permission.AD_ID"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "pharma.ritom.in",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "16.1",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBFirestore",
              "RNFBFunctions",
              "RNFBStorage"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/images",
            "./assets/data"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow OpenPharma to access your camera to scan barcodes.",
          "microphonePermission": false
        }
      ],
      "expo-image-picker",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.7881873473-b7i29gku63is5op9d5mtqgo2p3fuoc7b"
        }
      ],
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2032620092700178~5398079799",
          "iosAppId": "ca-app-pub-2032620092700178~6107488826",
          "userTrackingUsageDescription": "This allows us to show you relevant health and lifestyle advertisements based on your needs."
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8ceab29c-f8e6-4ec9-86d1-bfa3894af280"
      }
    }
  }
}
